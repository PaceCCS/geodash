{
  "name": "geodash-app",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,ELECTRON_TS,ELECTRON \"bun run dev:web\" \"bunx tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"bunx wait-on http://127.0.0.1:3000 dist-electron/main.js dist-electron/preload.js && bunx electron dist-electron/main.js\"",
    "dev:web": "vite dev --strictPort --port 3000 --host 0.0.0.0",
    "build": "bun run build:web && bun run build:electron",
    "build:web": "vite build",
    "build:electron": "bunx tsc -p tsconfig.electron.json",
    "lint": "bunx eslint src/",
    "start:desktop": "bun run build && bunx electron dist-electron/main.js",
    "preview": "vite preview",
    "test": "bun test",
    "test:e2e": "bun run build:electron && bunx playwright test",
    "test:e2e:headed": "bun run build:electron && bunx playwright test --headed"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/query-db-collection": "^1.0.33",
    "@tanstack/react-db": "^0.1.80",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router": "1.168.8",
    "@tanstack/react-start": "1.167.13",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "1.167.9",
    "@xyflow/react": "12.10.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/parser": "8.57.2",
    "@types/bun": "^1.3.11",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "^9.2.1",
    "electron": "41.1.0",
    "eslint": "10.1.0",
    "playwright": "^1.58.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "wait-on": "^9.0.4"
  }
}
