{
  "name": "geodash-app",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n RENDERER,ELECTRON_TS,ELECTRON \"bun run dev:web\" \"bunx tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"bunx wait-on http://127.0.0.1:3000 dist-electron/main.js dist-electron/preload.js && bunx electron dist-electron/main.js\"",
    "dev:web": "vite dev --port 3000 --host 0.0.0.0",
    "build": "bun run build:web && bun run build:electron",
    "build:web": "vite build",
    "build:electron": "bunx tsc -p tsconfig.electron.json",
    "start:desktop": "bun run build && bunx electron dist-electron/main.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.0",
    "@tanstack/react-db": "^0.1.72",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.161.3",
    "@tanstack/react-start": "^1.161.3",
    "@tanstack/router-plugin": "^1.161.3",
    "@xyflow/react": "^12.10.1",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
