{
  "extends": "./tsconfig.json",
  "include": ["electron/**/*.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "electron"],
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "sourceMap": true
  }
}
