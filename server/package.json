{
  "name": "geodash-server",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "build:wasm": "cd ../core/network-engine && zig build wasm && cp zig-out/bin/geodash.wasm ../server/wasm/geodash.wasm"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "effect": "^3.19.19",
    "elysia": "^1.4.27",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.1",
    "typescript": "^5.9.3"
  }
}
